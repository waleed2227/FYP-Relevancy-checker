# Local development — copy to .env
VITE_API_URL=http://localhost:8000/api/v1

# Vercel Production — set in Project Settings → Environment Variables (do NOT commit):
# VITE_API_URL=https://YOUR_EC2_DOMAIN_OR_IP/api/v1
# Must be HTTPS if the Vercel site is HTTPS (avoid mixed-content blocking).
# Must include /api/v1 (matches backend API_PREFIX).
