# =============================================================================
# Copy to .env:  copy .env.example .env
# IMPORTANT: DB_PASSWORD must match your PostgreSQL installation password!
# =============================================================================

APP_NAME=AI-Based FYP Relevancy System
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

HOST=0.0.0.0
PORT=8000

# PostgreSQL – change DB_PASSWORD to your real postgres user password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fyp_relevancy_system
DB_USER=postgres
DB_PASSWORD=postgres123

# (Optional) Not required – app builds URL from DB_* fields above
# DATABASE_URL=postgresql+asyncpg://postgres:postgres123@localhost:5432/fyp_relevancy_system

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800

SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public URL of the frontend (used to build the reset link inside the email)
FRONTEND_BASE_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Email / SMTP for "Forgot Password" reset links.
# Leave SMTP_HOST empty to disable email (reset link is logged to the server console).
# Gmail example: create an App Password at https://myaccount.google.com/apppasswords
#   SMTP_HOST=smtp.gmail.com
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password
#   SMTP_FROM_EMAIL=youraddress@gmail.com
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI FYP Relevancy System
SMTP_USE_TLS=true

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

OPENAI_API_KEY=

# Ollama – natural-language relevancy explanations (similarity uses BOW or V2 semantic engine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_ENABLED=true
OLLAMA_TIMEOUT_SECONDS=120

# Relevancy corpus: 0 = compare against all projects (no limit)
RELEVANCY_CORPUS_LIMIT=0

# AI relevancy V2 — semantic embeddings (wired to similarity scoring when enabled)
RELEVANCY_ENGINE_V2_ENABLED=false
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2
SENTENCE_TRANSFORMER_DEVICE=cpu

# Hugging Face token — avoids HTTP 429 when downloading all-MiniLM-L6-v2
# Create at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxx
